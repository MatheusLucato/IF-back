# Porta da API
PORT=3001

# Ambiente da aplicacao
NODE_ENV=development

# Service-role key do Supabase (operacoes privilegiadas no backend).
# Formatos aceitos:
# 1) project_ref|sb_secret_xxx
# 2) https://project_ref.supabase.co|sb_secret_xxx
# 3) chave JWT legacy service_role (ref extraido automaticamente)
SUPABASE_SECRET_KEY=
SUPABASE_ANON_KEY=


# Frontend permitido (pode ter mais de um separado por virgula)
# Exemplo: https://if-front.onrender.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Admin padrao (criado automaticamente se nao existir)
DEFAULT_ADMIN_EMAIL=admin@igrejafamilia.com
DEFAULT_ADMIN_PASSWORD=admin123

# --- Cloudflare R2 (armazenamento de logos/fotos) ---
# Enquanto estas variaveis estiverem vazias, o upload cai num fallback que
# devolve data URL (comportamento legado) e nada quebra. Preencha-as para
# que os assets passem a ser gravados no R2.
#
# Account ID da sua conta Cloudflare (usado para montar o endpoint S3).
R2_ACCOUNT_ID=
# Credenciais do R2 (Cloudflare > R2 > Manage API Tokens > S3 credentials).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Nome do bucket.
R2_BUCKET=
# Base publica para servir os assets: dominio custom (https://cdn.suaigreja.com)
# ou o subdominio publico r2.dev do bucket. OBRIGATORIA para usar o R2.
R2_PUBLIC_BASE_URL=
# (Opcional) sobrescreve o endpoint S3; por padrao usa
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# --- Gateway de pagamento (Fase 6: doacoes PIX/cartao, boletos F5.7) ---
# Enquanto PAYMENTS_API_KEY estiver vazia, as doacoes online e boletos respondem
# "gateway nao configurado" com instrucao clara (nada quebra; o restante do
# financeiro funciona normalmente). Preencha para habilitar pagamentos reais.
#
# Provedor: 'asaas' (default, cobre PIX+cartao+boleto, popular entre igrejas) ou
# 'mock' (simulacao local, NUNCA em producao — marca como pago sem cobrar).
PAYMENTS_PROVIDER=asaas
# Ambiente do provedor: 'sandbox' (default) ou 'production'.
PAYMENTS_ENV=sandbox
# Chave de API do provedor (Asaas > Configuracoes > Integracoes > Chave de API).
PAYMENTS_API_KEY=
# Token que valida os webhooks recebidos. No Asaas, configure o mesmo valor no
# webhook do painel; ele chega no header `asaas-access-token` e e comparado aqui.
PAYMENTS_WEBHOOK_SECRET=

# --- Inteligência / IA (F10.3, Onda 6) ---
# Chave da API da Anthropic (console.anthropic.com) — usada SOMENTE no backend
# para as gerações com a Claude. Sem ela, o Assistente de IA responde
# "nao configurado" e nada quebra (painel e relatorios funcionam normalmente).
ANTHROPIC_API_KEY=
# (Opcional) Id do modelo Claude. Default: claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8
